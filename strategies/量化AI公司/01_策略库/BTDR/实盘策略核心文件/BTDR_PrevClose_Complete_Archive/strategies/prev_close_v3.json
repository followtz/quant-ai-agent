  },

  "parameters": {
    "sell_trigger": {
      "type": "TurboA",
      "condition": "price >= prev_close * (1 + sell_threshold)",
      "sell_threshold_pct": 12,
      "sell_threshold": 0.12,
      "unit": "relative_to_prev_close"
    },
    "buyback_trigger_A": {
      "type": "TurboA_buyback",
      "condition": "price <= prev_close_A_sell_day * (1 + A_offset)",
      "offset_pct": -1,
      "offset": -0.01,
      "unit": "prev_close_minus_1pct"
    },
    "buy_trigger": {
      "type": "TurboB",
      "condition": "price <= prev_close * (1 - buy_threshold)",
      "buy_threshold_pct": 5,
      "buy_threshold": 0.05,
      "unit": "relative_to_prev_close"
    },
    "sellback_trigger_B": {
      "type": "TurboB_sellback",
      "condition": "price >= prev_close_B_buy_day * (1 + B_offset)",
      "offset_pct": 5,
      "offset": 0.05,
      "unit": "prev_close_plus_5pct"
    }
  },

